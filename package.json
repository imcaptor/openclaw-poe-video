{
  "name": "@imcaptor/openclaw-poe-video",
  "version": "1.1.0",
  "description": "OpenClaw video generation provider for Poe video bots",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "README_en.md"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.7",
      "minGatewayVersion": "2026.5.7"
    },
    "build": {
      "openclawVersion": "2026.5.7",
      "pluginSdkVersion": "2026.5.7"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "poe",
    "video-generation",
    "veo",
    "seedance",
    "grok"
  ],
  "author": "imcaptor",
  "license": "MIT",
  "peerDependencies": {
    "openclaw": ">=2026.5.7"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
